{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Elephant Pod",
  "version": "0.2.0",
  "identifier": "com.elephanthand.elephantpod",
  "build": {
    "beforeDevCommand": "npm --workspace @elephant-pod/web run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --workspace @elephant-pod/web run build",
    "frontendDist": "../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Elephant Pod",
        "width": 1240,
        "height": 820,
        "minWidth": 390,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
