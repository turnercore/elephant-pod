# Copy to `.env` and replace every `CHANGE_ME` value before exposing this stack.
# This bundle can provide auth + Postgres for the app server.
# Generate `JWT_SECRET` with: `openssl rand -base64 32`
# Generate `ANON_KEY` and `SERVICE_ROLE_KEY` as JWTs signed with `JWT_SECRET`.

POSTGRES_PASSWORD=CHANGE_ME_postgres_password
POSTGRES_DB=postgres
POSTGRES_PORT=5432
JWT_SECRET=CHANGE_ME_at_least_32_characters
ANON_KEY=CHANGE_ME_signed_anon_jwt
SERVICE_ROLE_KEY=CHANGE_ME_signed_service_role_jwt
# Studio dashboard login for the local admin UI.
DASHBOARD_USERNAME=elephant
DASHBOARD_PASSWORD=CHANGE_ME_dashboard_password
# Public URLs expected by the auth flow and the app server.
SITE_URL=http://localhost:8787
API_EXTERNAL_URL=http://localhost:8000
SUPABASE_PUBLIC_URL=http://localhost:8000
STUDIO_DEFAULT_ORGANIZATION=Elephant Hand
STUDIO_DEFAULT_PROJECT=Elephant Pod
# Mailpit keeps magic-link mail local during development.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_ADMIN_EMAIL=admin@example.com
SMTP_SENDER_NAME=Elephant Pod
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
# GitHub OAuth is optional, but the app server expects the same values if you use it.
GOTRUE_EXTERNAL_GITHUB_ENABLED=true
GOTRUE_EXTERNAL_GITHUB_CLIENT_ID=CHANGE_ME_github_client_id
GOTRUE_EXTERNAL_GITHUB_SECRET=CHANGE_ME_github_client_secret
GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI=${API_EXTERNAL_URL}/auth/v1/callback
PGRST_DB_SCHEMAS=public,storage,graphql_public
IMGPROXY_ENABLE_WEBP_DETECTION=true
# Server-side media/rendering toggles used by the app server.
CLIP_RENDER_ENABLED=true
SILENCE_RENDER_ENABLED=true
SERVER_PUBLIC_URL=http://localhost:8787
VITE_API_BASE_URL=http://localhost:8787

# Server-only API credentials for app-server deployments
PODCASTINDEX_API_KEY=CHANGE_ME
PODCASTINDEX_API_SECRET=CHANGE_ME
PODCASTINDEX_USER_AGENT=elephant-pod/0.2.0 (+https://example.com/contact)
