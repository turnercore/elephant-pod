# Copy this to `.env` for app server runs.
# Keep every secret/server-only value out of the client bundle.
# Replace all `CHANGE_ME_*` values before release.

# Public client config (safe to expose in frontend bundles)
VITE_API_BASE_URL=http://localhost:8787
# Use `server` for browser-hosted builds that must use their own origin.
VITE_RUNTIME_MODE=local

# Server public contract. In production this must be the browser-facing origin,
# for example `https://pod.elephanthand.com`.
PORT=8787
SERVER_PUBLIC_URL=http://localhost:8787

# Server-side data backend (server-only)
DATABASE_URL=postgresql://postgres:elephantpod@localhost:54322/elephant_pod

# Auth provider (server-only)
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=CHANGE_ME_signed_anon_jwt
# Optional privileged Supabase key for self-hosted setups and server-only actions.
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_signed_service_role_jwt

# Optional OAuth provider config (server-only, if used)
GOTRUE_EXTERNAL_GITHUB_ENABLED=true
GOTRUE_EXTERNAL_GITHUB_CLIENT_ID=CHANGE_ME_github_client_id
GOTRUE_EXTERNAL_GITHUB_SECRET=CHANGE_ME_github_client_secret
GOTRUE_EXTERNAL_GITHUB_REDIRECT_URI=${API_EXTERNAL_URL}/auth/v1/callback

# Supabase auth callback/site expectations
SITE_URL=http://localhost:8787
API_EXTERNAL_URL=http://localhost:8000

# PodcastIndex discovery credentials (server-only)
PODCASTINDEX_API_KEY=CHANGE_ME
PODCASTINDEX_API_SECRET=CHANGE_ME
PODCASTINDEX_USER_AGENT=elephant-pod/0.2.0 (+https://example.com/contact)

# FFmpeg/media controls
CLIP_RENDER_ENABLED=true
SILENCE_RENDER_ENABLED=true
SILENCE_THRESHOLD_DB=-42
SILENCE_MINIMUM_SEC=0.7
SILENCE_RETAINED_SEC=0.25
SILENCE_ANALYZER_VERSION=v1
FFMPEG_PATH=ffmpeg

# Smart Skip is signed-in server processing. Local/offline playback does not use it.
# The localhost worker URLs and MOCK_* flags are for local integration only.
# Real Smart Skip processing requires live Whisper and Codex/segmenter endpoints.
SMART_SKIP_ENABLED=false
SMART_SKIP_REQUIRE_AUTH=true
SMART_SKIP_WHISPER_BASE_URL=http://localhost:8001
SMART_SKIP_WHISPER_MODEL=large-v3-turbo
SMART_SKIP_SEGMENTER_BASE_URL=http://localhost:8002
SMART_SKIP_SEGMENTER_MODEL=gpt-5.4-mini
SMART_SKIP_PROACTIVE_ENABLED=false
SMART_SKIP_ACTIVE_USER_DAYS=30
SMART_SKIP_PROACTIVE_RUNS_PER_DAY=2
SMART_SKIP_MAX_PROACTIVE_EPISODES_PER_SHOW=3
SMART_SKIP_MAX_BACKLOG_PER_USER_PER_DAY=25
SMART_SKIP_PROCESSING_CONCURRENCY=1
MOCK_WHISPER=true
MOCK_SEGMENTER=true
# Required by apps/segmenter when MOCK_SEGMENTER=false.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
